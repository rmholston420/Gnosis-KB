# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=gnosis
POSTGRES_USER=gnosis
POSTGRES_PASSWORD=gnosis_secret
# Use Docker service names as hostnames (not localhost) when running via docker compose
DATABASE_URL=postgresql+asyncpg://gnosis:gnosis_secret@postgres:5432/gnosis
DATABASE_URL_SYNC=postgresql+psycopg2://gnosis:gnosis_secret@postgres:5432/gnosis

# ── Vector Store ───────────────────────────────────────────────────────────────
# Use Docker service name 'qdrant' (not localhost) when running via docker compose
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=gnosis_notes

# ── Vault ──────────────────────────────────────────────────────────────────────
VAULT_PATH=/vault
LIGHTRAG_WORKING_DIR=/lightrag

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-replace-in-production-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days
AUTH_REQUIRED=false         # Set true to enforce JWT login screen
INITIAL_ADMIN_EMAIL=admin@gnosis.local
INITIAL_ADMIN_PASSWORD=gnosis_admin

# ── AI Providers (optional — Ollama is default) ────────────────────────────────
# host.docker.internal reaches Ollama running on the host machine from inside Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# External LLM fallbacks (optional)
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3010","http://localhost:5173","http://localhost:8080"]

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=text              # "json" for production log aggregators
DEBUG=false
ENABLE_PDF_EXPORT=false      # Set true + pip install weasyprint for PDF export
