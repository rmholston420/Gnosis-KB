# =============================================================================
# Gnosis Knowledge Base — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=change_in_production
DATABASE_URL=postgresql+asyncpg://gnosis:${POSTGRES_PASSWORD}@gnosis-db:5432/gnosis

# -----------------------------------------------------------------------------
# Vector Store
# -----------------------------------------------------------------------------
QDRANT_URL=http://gnosis-vector:6333

# -----------------------------------------------------------------------------
# Vault — path to your Markdown notes directory
# -----------------------------------------------------------------------------
VAULT_PATH=./vault

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=change_in_production_immediately
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# AI Providers
# Ollama is the default (local). External providers are optional fallbacks.
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://gnosis-ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# External LLM fallbacks (leave blank to disable)
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
LOG_LEVEL=info
DEBUG=false

# Frontend
VITE_API_BASE_URL=http://localhost:8010
