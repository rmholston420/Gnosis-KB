# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_in_production
DATABASE_URL=postgresql+asyncpg://gnosis:${POSTGRES_PASSWORD}@gnosis-db:5432/gnosis

# ── Vector Store ───────────────────────────────────────────────────────────────
QDRANT_URL=http://gnosis-vector:6333

# ── Vault ──────────────────────────────────────────────────────────────────────
VAULT_PATH=./vault          # Absolute or relative path to your Markdown vault

# ── Auth ───────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days
AUTH_REQUIRED=false         # Set true to enforce JWT login screen
INITIAL_ADMIN_EMAIL=admin@gnosis.local
INITIAL_ADMIN_PASSWORD=gnosis_admin

# ── AI Providers (optional — Ollama is default) ────────────────────────────────
OLLAMA_BASE_URL=http://gnosis-ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# External LLM fallbacks (optional)
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=text              # "json" for production log aggregators
DEBUG=false
ENABLE_PDF_EXPORT=false      # Set true + pip install weasyprint for PDF export
