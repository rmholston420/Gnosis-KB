# Gnosis Knowledge Base — Environment Variables
# Copy to .env and fill in your values.
# In production, run ./deploy.sh — it patches this file automatically.

# ---- Database ----
POSTGRES_DB=gnosis
POSTGRES_USER=gnosis
POSTGRES_PASSWORD=gnosis_secret
DATABASE_URL=postgresql+asyncpg://gnosis:gnosis_secret@localhost:5432/gnosis
DATABASE_URL_SYNC=postgresql+psycopg2://gnosis:gnosis_secret@localhost:5432/gnosis

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=gnosis_notes

# ---- Vault ----
VAULT_PATH=/home/YOUR_USERNAME/gnosis-vault
LIGHTRAG_WORKING_DIR=/home/YOUR_USERNAME/.gnosis/lightrag

# ---- Ollama (local LLM) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- Cloud LLM providers (optional fallbacks) ----
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ---- Security ----
# REQUIRED: Change in production! Generate with: openssl rand -hex 32
SECRET_KEY=changeme-replace-in-production-with-a-long-random-string

# ---- CORS ----
# In production, Nginx handles CORS at the proxy layer.
# This value covers direct API access (dev + health checks).
CORS_ORIGINS=["http://localhost:3010","http://localhost:5173","http://localhost:8080"]

# ---- TLS (production only) ----
# Path to directory containing fullchain.pem + privkey.pem
# deploy.sh sets this automatically to /etc/letsencrypt/live/<DOMAIN>
# For local dev, leave unset (falls back to ./nginx/certs/)
TLS_CERT_DIR=

# ---- Domain (production only) ----
# Used by deploy.sh to patch nginx.conf server_name and request the cert.
DOMAIN=
