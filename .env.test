# ── Test environment — used by: cd backend && pytest ────────────────────────
# Copy this file to backend/.env before running pytest locally.
# All external services are stubbed out in conftest.py; these vars just
# prevent pydantic-settings from raising validation errors on startup.

# Database — SQLite; the test_engine fixture creates an in-memory DB
DATABASE_URL=sqlite+aiosqlite:///./test_gnosis.db

# Qdrant — not used in tests (ensure_collection is patched)
QDRANT_URL=http://localhost:6333

# Ollama — not used in tests (llm_provider.initialize is no-op on empty URL)
OLLAMA_BASE_URL=
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI — stub key satisfies pydantic validation without real calls
OPENAI_API_KEY=test-key

# Auth — any 32-char string works for signing test JWTs
SECRET_KEY=test-secret-key-minimum-32-chars!!
AUTH_REQUIRED=false

# Vault — overridden per-test by vault_dir fixture; value here is a fallback
VAULT_PATH=/tmp/gnosis-vault-test

# LightRAG — not used in tests (graph_rag.initialize is patched)
LIGHTRAG_WORKING_DIR=/tmp/gnosis-lightrag-test

# Logging — keep tests quiet
LOG_LEVEL=warning
LOG_FORMAT=text
DEBUG=false
