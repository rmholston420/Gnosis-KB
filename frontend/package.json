    "@vitest/coverage-v8":             "^1.4.0",
    "autoprefixer":                     "^10.4.18",
    "eslint":                           "^8.57.0",
    "eslint-plugin-react-hooks":        "^4.6.0",
    "eslint-plugin-react-refresh":      "^0.4.5",
    "jsdom":                            "^24.0.0",
    "postcss":                          "^8.4.35",
    "tailwindcss":                      "^3.4.1",
    "typescript":                       "^5.2.2",
    "vite":                             "^5.1.6",
