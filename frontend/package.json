    "date-fns":                        "^3.6.0",
    "fuse.js":                         "^7.0.0",
    "lucide-react":                    "^0.363.0",
    "marked":                          "^12.0.0",
    "react":                           "^18.2.0",
    "react-dom":                       "^18.2.0",
    "react-dropzone":                  "^14.2.3",
    "react-force-graph-2d":            "^1.25.4",
